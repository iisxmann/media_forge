# MediaForge configuration

# General
MEDIAFORGE_ENV=development
MEDIAFORGE_LOG_LEVEL=INFO
MEDIAFORGE_OUTPUT_DIR=./output
MEDIAFORGE_TEMP_DIR=./temp
MEDIAFORGE_CACHE_DIR=./cache

# FFmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# AI Model Paths
WHISPER_MODEL_SIZE=base
WHISPER_MODEL_DIR=./models/whisper
YOLO_MODEL_PATH=./models/yolo/yolov8n.pt

# Tesseract OCR
TESSERACT_CMD=tesseract

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_MAX_UPLOAD_SIZE=500

# Cache
CACHE_ENABLED=true
CACHE_MAX_SIZE_MB=1024
CACHE_TTL_SECONDS=3600
